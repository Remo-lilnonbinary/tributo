{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/product/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|tone|shape|src|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, size, tone, shape, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|gold|soft)$/]",
        "message": "<Avatar> tone must be one of 'ink' | 'gold' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle)$/]",
        "message": "<Avatar> shape must be one of 'rounded' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, size, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|ink|gold|solid|alert)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'ink' | 'gold' | 'solid' | 'alert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|shape|fullWidth|disabled|iconLeft|iconRight|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, shape, fullWidth, disabled, iconLeft, iconRight, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:round|pill)$/]",
        "message": "<Button> shape must be one of 'round' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padding|interactive|accent|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padding, interactive, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|raised|sunken|dark)$/]",
        "message": "<Card> variant must be one of 'default' | 'raised' | 'sunken' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmailRecipient'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|company|key|ref|className|style|children)$/]",
        "message": "<EmailRecipient> doesn't accept that prop. Declared props: name, role, company."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmpathyMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|floor|caption|size|key|ref|className|style|children)$/]",
        "message": "<EmpathyMeter> doesn't accept that prop. Declared props: label, value, floor, caption, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmpathyMeter'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<EmpathyMeter> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GateStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|state|detail|variant|key|ref|className|style|children)$/]",
        "message": "<GateStatus> doesn't accept that prop. Declared props: name, state, detail, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='GateStatus'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:pass|fail|checking)$/]",
        "message": "<GateStatus> state must be one of 'pass' | 'fail' | 'checking'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GateStatus'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:row|chip)$/]",
        "message": "<GateStatus> variant must be one of 'row' | 'chip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|size|leading|trailing|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, size, leading, trailing."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|trust|verified|size|key|ref|className|style|children)$/]",
        "message": "<SourceChip> doesn't accept that prop. Declared props: type, label, trust, verified, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceChip'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:call|crm|deal|web|enrichment)$/]",
        "message": "<SourceChip> type must be one of 'call' | 'crm' | 'deal' | 'web' | 'enrichment'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceChip'] > JSXAttribute[name.name='trust'] > Literal[value!=/^(?:high|medium|low)$/]",
        "message": "<SourceChip> trust must be one of 'high' | 'medium' | 'low'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<SourceChip> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|selected|onRemove|leading|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, selected, onRemove, leading, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|gold|outline)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'gold' | 'outline'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
