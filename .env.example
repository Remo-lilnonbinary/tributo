# --- FLock inference (the one true runtime dependency) ---
# Without a key the backend serves a clearly-labelled local fallback answer so the app still runs and demos end-to-end. Requries credit from platform.flock.io for live inference.
FLOCK_API_KEY= your-flock-api-key-here
FLOCK_BASE_URL=https://api.flock.io/v1
FLOCK_MODEL=qwen3-30b-a3b-instruct-2507

# --- Backends ---
# REDACTOR: auto between presidio or regex if presidio is installed
REDACTOR=your-redactor-here
# RETRIEVER: bm25 | embeddings
RETRIEVER=your-retriever-here
# CORS_ORIGINS: comma-separated allowlist of frontend origins ("*" for local dev only)
CORS_ORIGINS= your-cors-origins-here

# --- Voice Feature: LiveKit Agents + Deepgram + ElevenLabs ---
LIVEKIT_URL= your-livekit-url-here  
LIVEKIT_API_KEY= your-livekit-api-key-here
LIVEKIT_API_SECRET= your-livekit-api-secret-here
DEEPGRAM_API_KEY= your-deepgram-api-key-here
ELEVEN_API_KEY= your-elevenlabs-api-key-here
VOICE_ID= your-elevenlabs-voice-id-here
